public class Stack {

    private int[] stack;
    private int ponteiro;
    private Semaphore mutex;
    private Semaphore produtor;
    private Semaphore consumidor;
    
    Stack() {
        this.stack = new int[1000];
        this.ponteiro = -1;
        this.mutex = new Semaphore(1);
        this.produtor = new Semaphore(0);
        this.consumidor = new Semaphore(1000);

    }

    public boolean isEmpty() {
        boolean retorno = false;
        
        mutex.wait();
        if (ponteiro == -1) {
            retorno = true;
        }
        mutex.signal();

        return retorno;
    }

    // Consumidor 
    public int pop() {
        produtor.wait();
        mutex.wait();

          int retorno = stack[ponteiro];
          ponteiro--;

        mutex.signal();
  consumidor.signal();
        return retorno;
    }

    // Produtor
    public void push(int value) {
        consumidor.wait();
        mutex.wait();

          ponteiro++;
          stack[ponteiro] = value;

        mutex.signal();
        produtor.signal();
    }
