    class Broker {
    private Request[] requests;
    private int capacity;
    private int head = 0, tail = 0;
    
    private Semaphore mutex = new Semaphore(1);
    private Semaphore vagas;  // Controla se o vetor está cheio 
    private Semaphore itens;  // Controla se há requests disponíveis 

    public Broker(int n) {
        this.capacity = n;
        this.requests = new Request[n];
        this.vagas = new Semaphore(n); // Inicia com N vagas [cite: 84]
        this.itens = new Semaphore(0); // Inicia com 0 itens
    }

    public void submitRequest(Request req) {
        vagas.wait();    // Bloqueia se estiver cheio 
        mutex.wait();
        
        requests[tail] = req;
        tail = (tail + 1) % capacity;
        
        mutex.signal();
        itens.signal();  // Avisa que há trabalho disponível
    }

    public Request getWork() {
        itens.wait();    // Bloqueia se não houver requests 
        mutex.wait();
        
        Request req = requests[head];
        head = (head + 1) % capacity;
        
        mutex.signal();
        vagas.signal();  // Libera uma vaga no vetor
        return req;
    }
}
class Worker {
    private Broker broker;

    public Worker(Broker broker) {
        this.broker = broker;
    }

    public void run() {
        while (true) { // Loop infinito conforme solicitado 
            Request req = broker.getWork(); // Retira do broker 
            exec(req);                      // Executa o request 
        }
    }
    
    // Método exec não precisa ser implementado 
    private void exec(Request req) { /* ... */ }
}
public static void main(String[] args) {
    int N = 50; // Constante N conhecida [cite: 96]
    Broker broker = new Broker(N);
    
    // Criar 7 threads para executar os workers 
    for (int i = 0; i < 7; i++) {
        Worker w = new Worker(broker);
        create_thread(w.run); // Criação conforme API da prova [cite: 67]
    }
    
