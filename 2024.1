void wrap_write(data d) {
    mutex_E.wait();
    e_count++;
    if (e_count == 1) read_block.wait(); // O primeiro escritor "tranca o portão" para novos leitores
    mutex_E.signal();

    resource.wait();   // Espera sua vez de escrever (exclusividade total)
    write(d);          // Operação de escrita
    resource.signal(); // Libera para o próximo (escritor ou leitor)

    mutex_E.wait();
    e_count--;
    if (e_count == 0) read_block.signal(); // O último escritor "abre o portão" para os leitores
    mutex_E.signal();
}
data wrap_read() {
    read_block.wait();   // Tenta passar pelo portão (se um escritor estiver esperando, aqui ele trava)
    mutex_L.wait();
    l_count++;
    if (l_count == 1) resource.wait(); // O primeiro leitor bloqueia o recurso contra escritores
    mutex_L.signal();
    read_block.signal(); // Libera o portão para o próximo leitor passar

    data d = read();     // Operação de leitura simultânea

    mutex_L.wait();
    l_count--;
    if (l_count == 0) resource.signal(); // O último leitor libera o recurso para escritores
    mutex_L.signal();
    
    return d;
}
