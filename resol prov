mutex = new Sem(1)
done = new Sem(0)
int cont = 0

func void worker(index, url, route)
    p = price(url, route)

    mutex.wait()
        if p < menor:
            menor = p
            provider_index = index
        cont++

        if cont == threshold
            done.signal()

    mutex.signal()
}

int main(String args[]) {

    route = args[0]
    providers_total = length(args) - 1

    threshold = ceil(providers_total / 2)

    for i in 0 to providers_total-1
        url = args[i+1]
        create_thread(worker, i, url, route)

    done.wait()
    return provider_index
}
